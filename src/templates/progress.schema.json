{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hxflow.dev/schemas/progress.schema.json",
  "title": "HXFlow progress.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature",
    "requirementDoc",
    "planDoc",
    "createdAt",
    "updatedAt",
    "completedAt",
    "lastRun",
    "tasks"
  ],
  "properties": {
    "feature": {
      "type": "string",
      "minLength": 1
    },
    "requirementDoc": {
      "type": "string",
      "minLength": 1
    },
    "planDoc": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "lastRun": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "taskId",
            "taskName",
            "status",
            "exitStatus",
            "exitReason",
            "ranAt"
          ],
          "properties": {
            "taskId": {
              "type": "string",
              "minLength": 1
            },
            "taskName": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "in-progress",
                "done"
              ]
            },
            "exitStatus": {
              "type": "string",
              "enum": [
                "succeeded",
                "failed",
                "aborted",
                "blocked",
                "timeout"
              ]
            },
            "exitReason": {
              "type": "string"
            },
            "ranAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "status",
          "dependsOn",
          "parallelizable",
          "output",
          "startedAt",
          "completedAt",
          "durationSeconds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in-progress",
              "done"
            ]
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "parallelizable": {
            "type": "boolean"
          },
          "output": {
            "type": "string",
            "maxLength": 200
          },
          "startedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "completedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "durationSeconds": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          }
        }
      }
    }
  }
}
