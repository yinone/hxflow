{
  "name": "@hxflow/cli",
  "version": "2.0.0",
  "description": "Project-rules-driven AI engineering workflow — zero-disruption installer for existing projects.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hx": "bin/hx.js"
  },
  "files": [
    ".npmrc",
    "bin/hx.js",
    "README.md",
    "src/agents/**/*",
    "src/pipelines/**/*.yaml",
    "src/templates/**/*",
    "src/scripts/hx-setup.js",
    "src/scripts/hx-upgrade.js",
    "src/scripts/hx-uninstall.js",
    "src/scripts/hx-doctor.js",
    "src/scripts/lib/config-utils.js",
    "src/scripts/lib/scan-project.js",
    "src/scripts/lib/derive-project-facts.js",
    "src/scripts/lib/render-rule-templates.js",
    "src/scripts/lib/rule-context.js",
    "src/scripts/lib/install-utils.js",
    "src/scripts/lib/resolve-context.js"
  ],
  "scripts": {
    "pack:dry-run": "npm pack --dry-run",
    "release:pack": "npm pack",
    "hx:test:unit": "vitest run tests/unit",
    "hx:test:integration": "vitest run tests/integration",
    "hx:test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.cdfsunrise.com/"
  }
}
