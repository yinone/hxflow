{
  "name": "your-project",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "// ── 文档工具 ──────────────────────────────────": "",
    "hx:doc":       "node scripts/hx-new-doc.js",
    "hx:plan":      "node scripts/hx-new-plan.js",
    "hx:ctx":       "node scripts/hx-ctx-check.js",

    "// ── 代码质量 ──────────────────────────────────": "",
    "hx:lint":      "eslint . --max-warnings 0",
    "hx:lint:fix":  "eslint . --fix",
    "hx:type":      "tsc --noEmit",
    "hx:test":      "vitest run --reporter=verbose",
    "hx:test:w":    "vitest --watch",
    "hx:test:cov":  "vitest run --coverage",

    "// ── 门控（顺序执行，任一失败即停）──────────────": "",
    "hx:gate":      "npm run hx:lint && npm run hx:type && npm run hx:test",
    "hx:check":     "npm run hx:ctx && npm run hx:gate",

    "// ── Agent 执行 ────────────────────────────────": "",
    "hx:run":       "node scripts/hx-agent-run.js",
    "hx:fix":       "node scripts/hx-agent-fix.js",

    "// ── 工作流辅助 ────────────────────────────────": "",
    "hx:review":    "node scripts/hx-review-checklist.js",
    "hx:done":      "node scripts/hx-task-done.js",

    "// ── 熵管理 ────────────────────────────────────": "",
    "hx:entropy":   "node scripts/hx-entropy-scan.js",
    "hx:clean":     "node scripts/hx-doc-freshness.js",

    "// ── 架构合规（CI 专用）────────────────────────": "",
    "hx:arch":      "node scripts/hx-arch-test.js",
    "ci":           "npm run hx:lint && npm run hx:type && npm run hx:test && npm run hx:arch && npm run hx:ctx"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "bash -c 'tsc --noEmit'"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write"
    ],
    "docs/**/*.md": [
      "prettier --write --prose-wrap always"
    ],
    "docs/plans/*.json": [
      "node -e \"const f=process.argv[1]; try{JSON.parse(require('fs').readFileSync(f,'utf8'));console.log('✓',f)}catch(e){console.error('✗ JSON invalid:',f);process.exit(1)}\" --"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
