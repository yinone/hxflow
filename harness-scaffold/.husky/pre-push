#!/bin/sh
# .husky/pre-push
# push 前完整门控：typecheck + test + arch
# 比 pre-commit 更重，只在 push 时执行一次

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# ── 禁止直接 push 到受保护分支 ───────────────────────────────
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ] || [ "$BRANCH" = "production" ]; then
  echo ""
  echo "✗ 禁止直接 push 到 $BRANCH 分支"
  echo "  请通过 Pull Request 流程合并"
  echo "  创建分支: git checkout -b feat/your-feature"
  echo ""
  exit 1
fi

echo "▸ [1/3] TypeScript 类型检查..."
npm run hx:type --silent
if [ $? -ne 0 ]; then
  echo ""
  echo "✗ TypeScript 类型错误，push 已阻断"
  echo "  运行 npm run hx:type 查看详细错误"
  exit 1
fi
echo "  ✓ 类型检查通过"

echo "▸ [2/3] 单元测试..."
npm run hx:test --silent
if [ $? -ne 0 ]; then
  echo ""
  echo "✗ 单元测试未通过，push 已阻断"
  echo "  运行 npm run hx:test:w 进入 watch 模式调试"
  exit 1
fi
echo "  ✓ 测试全部通过"

echo "▸ [3/3] 架构合规检查..."
npm run hx:arch --silent
if [ $? -ne 0 ]; then
  echo ""
  echo "✗ 架构层级违规，push 已阻断"
  echo "  查看 docs/map.md 确认正确的依赖方向"
  exit 1
fi
echo "  ✓ 架构合规通过"

echo ""
echo "✓ pre-push 全部通过，正在推送..."
exit 0
