#!/bin/sh
# .husky/commit-msg
# 强制 commit 消息格式，并校验 TASK-ID 格式

COMMIT_MSG=$(cat "$1")
PATTERN='^(feat|fix|docs|refactor|test|chore|ci|revert|style|perf)(\(.+\))?: .{5,72}$'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "✗ commit 消息格式不符合规范"
  echo ""
  echo "  格式: <type>(<scope>): <description>"
  echo "  类型: feat fix docs refactor test chore ci revert style perf"
  echo ""
  echo "  示例:"
  echo "    feat(auth): add login rate limiting [TASK-BE-03]"
  echo "    fix(ui): correct LoginForm loading state"
  echo "    docs(api): update auth endpoint documentation"
  echo ""
  echo "  当前消息: $COMMIT_MSG"
  echo ""
  exit 1
fi

# 如果消息包含 TASK-，校验格式
if echo "$COMMIT_MSG" | grep -q 'TASK-'; then
  if ! echo "$COMMIT_MSG" | grep -qE 'TASK-(FE|BE)-[0-9]{2}'; then
    echo "✗ TASK ID 格式应为 TASK-FE-01 或 TASK-BE-01"
    echo "  当前: $(echo "$COMMIT_MSG" | grep -o 'TASK-[^ ]*')"
    exit 1
  fi
fi

exit 0
