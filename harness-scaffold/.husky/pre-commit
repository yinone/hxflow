#!/bin/sh
# .husky/pre-commit
# 提交前门控：lint-staged + AGENTS.md 行数 + console.log 检测

# ── lint-staged（只检查改动的文件）────────────────────────────
echo "▸ 运行 lint-staged..."
npx lint-staged

if [ $? -ne 0 ]; then
  echo ""
  echo "✗ pre-commit 检查失败"
  echo "  运行 npm run hx:lint:fix 自动修复部分问题"
  echo "  运行 npm run hx:lint 查看完整错误列表"
  exit 1
fi

# ── AGENTS.md 行数检查（仅当 AGENTS.md 有改动时）───────────────
if git diff --cached --name-only | grep -q '^AGENTS\.md$'; then
  LINES=$(wc -l < AGENTS.md | tr -d ' ')
  if [ "$LINES" -gt 100 ]; then
    echo ""
    echo "✗ AGENTS.md 超过 100 行（当前 $LINES 行）"
    echo "  请精简后再提交。详细规则放 docs/ 下，AGENTS.md 只放索引。"
    exit 1
  fi
  echo "✓ AGENTS.md 行数检查通过（$LINES 行）"
fi

# ── console.log 检测（仅检查 src/ 下的 TS/TSX 文件）───────────
STAGED_SRC=$(git diff --cached --name-only | grep '^src/.*\.\(ts\|tsx\)$' | grep -v '\.test\.\|\.spec\.')

if [ -n "$STAGED_SRC" ]; then
  CONSOLE_HITS=$(git diff --cached -- $STAGED_SRC 2>/dev/null | grep '^+' | grep -v '^+++' | grep 'console\.\(log\|warn\|error\|debug\)')
  if [ -n "$CONSOLE_HITS" ]; then
    echo ""
    echo "✗ 检测到 console.log/warn/error 进入 src/（违反 GP-001）"
    echo "  请使用结构化 logger，参考 docs/golden-principles.md"
    echo ""
    echo "$CONSOLE_HITS" | head -5
    exit 1
  fi
fi

echo "✓ pre-commit 全部通过"
exit 0
